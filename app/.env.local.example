# 火山引擎方舟（豆包）配置
# 申请：https://www.volcengine.com/product/ark
ARK_API_KEY=your-ark-api-key
# 支持视觉的模型或接入点，如 doubao-seed-2-0-lite-260428 / doubao-1.5-vision-pro-32k-250115 / ep-xxxxxx
ARK_MODEL=doubao-seed-2-0-lite-260428
# 单次模型请求超时，默认 85000，允许范围 15000–100000 毫秒
# ARK_TIMEOUT_MS=85000

# 设为 1 时 /api/analyze 永远返回演示数据（比赛兜底开关）
# DEMO_MODE=1
